# SQLite (default — good for dev / single-family deployments)
DATABASE_URL=sqlite:///./data/family_finance.db
# PostgreSQL (production / multi-family) — uncomment & override:
# DATABASE_URL=postgresql+psycopg2://family:family_secret@localhost:5432/family_finance

# WhatsApp provider: "meta" (Meta Cloud API) or "greenapi" (Green API)
WHATSAPP_PROVIDER=meta

# --- Provider: Meta WhatsApp Cloud API ---
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=my_verify_token
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

# --- Provider: Green API (https://green-api.com) ---
# Get these from green-api.com console after creating an instance & scanning QR
GREENAPI_INSTANCE_ID=
GREENAPI_TOKEN=
GREENAPI_BASE_URL=https://api.green-api.com
GREENAPI_MEDIA_URL=https://media.green-api.com
GEMINI_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
TESSERACT_CMD=
APP_HOST=0.0.0.0
APP_PORT=8000
TIMEZONE=Asia/Kuala_Lumpur

# JWT auth — CHANGE THIS in production
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
